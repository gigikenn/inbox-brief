APP_HOST=127.0.0.1
APP_PORT=8000

# Persist Microsoft token cache (use on cloud with a mounted volume)
# DATA_DIR=/data

# Microsoft Entra / Azure App Registration
MS_CLIENT_ID=your-client-id
MS_TENANT_ID=common

# OpenAI (gpt-4o-mini is fast; use gpt-4o for higher quality)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Optional: require ?access_key=... on /digest and /digest/spoken (recommended on public URLs)
# DIGEST_ACCESS_KEY=long-random-secret

# Behavior
MAX_EMAILS_PER_RUN=25
AI_BATCH_CHUNK=15
IGNORE_SENDERS=no-reply@service.com,news@company.com
IGNORE_DOMAINS=newsletter.com,updates.example.com
VIP_SENDERS=boss@company.com,partner@client.com
